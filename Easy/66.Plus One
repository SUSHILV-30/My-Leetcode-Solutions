class Solution(object):
    def plusOne(self, digits):
        if digits[len(digits)-1] != 9:
           digits[len(digits)-1] = digits[len(digits)-1] + 1
           return digits

        elif digits[len(digits)-1] == 9:
            
            if len(digits)-1 == 0 :
                digits[len(digits)-1] = 1
                digits.append(0)
                return digits

            else:
                for i in range(len(digits)-1,-1,-1):
                    if digits[i] == 9:
                        digits[i] = 0

                    else:
                        digits[i] = digits[i] + 1
                        return digits

                digits.insert(0,1)
                return digits
                    


        
