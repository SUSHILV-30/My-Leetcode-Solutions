class Solution(object):
    def addBinary(self, a, b):

        # make both strings same length
        max_len = max(len(a), len(b))

        a = a.zfill(max_len)
        b = b.zfill(max_len)

        c = []
        carry = False

        # single for loop from back
        for i in range(len(a)-1, -1, -1):

            # one 1 and one 0
            if (a[i] == "1" and b[i] == "0") or \
               (a[i] == "0" and b[i] == "1"):

                if carry == True:
                    c.append("0")
                    carry = True
                else:
                    c.append("1")
                    carry = False

            # both 0
            elif a[i] == "0" and b[i] == "0":

                if carry == True:
                    c.append("1")
                    carry = False
                else:
                    c.append("0")
                    carry = False

            # both 1
            else:

                if carry == True:
                    c.append("1")
                    carry = True
                else:
                    c.append("0")
                    carry = True

        # remaining carry
        if carry == True:
            c.append("1")

        # reverse answer
        d = ""

        for i in range(len(c)-1, -1, -1):
            d = d + c[i]

        return d
